{
  "name": "pwrforge-vsc",
  "displayName": "pwrforge-vsc",
  "description": "pwrforge vscode plugin",
  "version": "0.0.1",
  "icon": "resources/pwrforge.png",
  "publisher": "WroclawUniversityOfScienceAndTechnology",
  "license": "MIT",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "pwrforge",
    "cpp",
    "C",
    "embedded",
    "docker",
    "build",
    "test",
    "lint"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pwrforge_container",
          "title": "Pwrforge",
          "icon": "resources/pwrforge.svg"
        }
      ]
    },
    "views": {
      "pwrforge_container": [
        {
          "id": "pwrforge_view",
          "name": "Actions",
          "icon": "resources/pwrforge.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "pwrforge.selectProject",
        "title": "Select Active Project",
        "category": "Pwrforge"
      },
      {
        "command": "pwrforge.setup",
        "title": "Setup Environment",
        "category": "Pwrforge"
      },
      {
        "command": "pwrforge.build",
        "title": "Pwrforge: Build",
        "icon": {
          "light": "resources/pwrforge.svg",
          "dark": "resources/pwrforge.svg"
        }
      },
      {
        "command": "pwrforge.test",
        "title": "Pwrforge: Test",
        "icon": {
          "light": "resources/pwrforge.svg",
          "dark": "resources/pwrforge.svg"
        }
      },
      {
        "command": "pwrforge.check",
        "title": "Pwrforge: Check",
        "icon": {
          "light": "resources/pwrforge.svg",
          "dark": "resources/pwrforge.svg"
        }
      },
      {
        "command": "pwrforge.fix",
        "title": "Pwrforge: Fix",
        "icon": {
          "light": "resources/pwrforge.svg",
          "dark": "resources/pwrforge.svg"
        }
      },
      {
        "command": "pwrforge.clean",
        "title": "Pwrforge: Clean"
      },
      {
        "command": "pwrforge.run",
        "title": "Pwrforge: Run"
      },
      {
        "command": "pwrforge.debug",
        "title": "Pwrforge: Debug"
      },
      {
        "command": "pwrforge.doc",
        "title": "Pwrforge: Doc"
      },
      {
        "command": "pwrforge.flash",
        "title": "Pwrforge: Flash"
      },
      {
        "command": "pwrforge.monitor",
        "title": "Pwrforge: Monitor"
      },
      {
        "command": "pwrforge.update",
        "title": "Pwrforge: Update"
      },
      {
        "command": "pwrforge.gen",
        "title": "Pwrforge: Gen"
      },
      {
        "command": "pwrforge.docker",
        "title": "Pwrforge: Docker…"
      },
      {
        "command": "pwrforge.publish",
        "title": "Pwrforge: Publish"
      },
      {
        "command": "pwrforge.licenseCheck",
        "title": "Pwrforge: License Check"
      },
      {
        "command": "pwrforge.new",
        "title": "Pwrforge: New…"
      },
      {
        "command": "pwrforge.version",
        "title": "Pwrforge: Version"
      },
      {
        "command": "pwrforge.more",
        "title": "Pwrforge: More…",
        "icon": {
          "light": "resources/pwrforge.svg",
          "dark": "resources/pwrforge.svg"
        }
      },
      {
        "command": "pwrforge.refresh",
        "title": "Pwrforge: Refresh View"
      },
      {
        "command": "pwrforge.dockerDoctor",
        "title": "Pwrforge: Docker doctor"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pwrforge.build",
          "when": "view == pwrforge_view",
          "group": "navigation"
        },
        {
          "command": "pwrforge.test",
          "when": "view == pwrforge_view",
          "group": "navigation"
        },
        {
          "command": "pwrforge.check",
          "when": "view == pwrforge_view",
          "group": "navigation"
        },
        {
          "command": "pwrforge.fix",
          "when": "view == pwrforge_view",
          "group": "navigation"
        },
        {
          "command": "pwrforge.more",
          "when": "view == pwrforge_view",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "pwrforge.build",
          "when": "explorerResourceIsFolder",
          "group": "navigation@100"
        },
        {
          "command": "pwrforge.test",
          "when": "explorerResourceIsFolder",
          "group": "navigation@101"
        },
        {
          "command": "pwrforge.check",
          "when": "explorerResourceIsFolder",
          "group": "navigation@102"
        },
        {
          "command": "pwrforge.fix",
          "when": "explorerResourceIsFolder",
          "group": "navigation@103"
        }
      ],
      "commandPalette": [
        {
          "command": "pwrforge.selectProject"
        },
        {
          "command": "pwrforge.setup"
        },
        {
          "command": "pwrforge.build"
        },
        {
          "command": "pwrforge.test"
        },
        {
          "command": "pwrforge.check"
        },
        {
          "command": "pwrforge.fix"
        },
        {
          "command": "pwrforge.clean"
        },
        {
          "command": "pwrforge.run"
        },
        {
          "command": "pwrforge.debug"
        },
        {
          "command": "pwrforge.doc"
        },
        {
          "command": "pwrforge.flash"
        },
        {
          "command": "pwrforge.monitor"
        },
        {
          "command": "pwrforge.update"
        },
        {
          "command": "pwrforge.gen"
        },
        {
          "command": "pwrforge.docker"
        },
        {
          "command": "pwrforge.publish"
        },
        {
          "command": "pwrforge.licenseCheck"
        },
        {
          "command": "pwrforge.new"
        },
        {
          "command": "pwrforge.version"
        },
        {
          "command": "pwrforge.more"
        },
        {
          "command": "pwrforge.refresh"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
